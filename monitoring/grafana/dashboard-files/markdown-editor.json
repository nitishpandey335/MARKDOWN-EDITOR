{
    "title": "Markdown Editor - Live Monitoring",
    "uid": "markdown-editor-main",
    "timezone": "browser",
    "refresh": "10s",
    "schemaVersion": 38,
    "tags": [
        "markdown-editor",
        "nodejs",
        "production"
    ],
    "panels": [
        {
            "id": 1,
            "title": "Backend Status",
            "type": "stat",
            "gridPos": {
                "x": 0,
                "y": 0,
                "w": 4,
                "h": 4
            },
            "options": {
                "colorMode": "background",
                "graphMode": "none",
                "textMode": "auto"
            },
            "targets": [
                {
                    "expr": "up{job=\"markdown-backend\"}",
                    "legendFormat": "Backend"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "mappings": [
                        {
                            "options": {
                                "0": {
                                    "text": "DOWN",
                                    "color": "red"
                                },
                                "1": {
                                    "text": "UP",
                                    "color": "green"
                                }
                            },
                            "type": "value"
                        }
                    ],
                    "thresholds": {
                        "steps": [
                            {
                                "color": "red",
                                "value": 0
                            },
                            {
                                "color": "green",
                                "value": 1
                            }
                        ]
                    }
                }
            }
        },
        {
            "id": 2,
            "title": "Total HTTP Requests",
            "type": "stat",
            "gridPos": {
                "x": 4,
                "y": 0,
                "w": 4,
                "h": 4
            },
            "options": {
                "colorMode": "background",
                "graphMode": "area"
            },
            "targets": [
                {
                    "expr": "sum(http_requests_total{job=\"markdown-backend\"})",
                    "legendFormat": "Total Requests"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "steps": [
                            {
                                "color": "blue",
                                "value": 0
                            }
                        ]
                    }
                }
            }
        },
        {
            "id": 3,
            "title": "Request Rate (req/sec)",
            "type": "stat",
            "gridPos": {
                "x": 8,
                "y": 0,
                "w": 4,
                "h": 4
            },
            "options": {
                "colorMode": "background",
                "graphMode": "area"
            },
            "targets": [
                {
                    "expr": "sum(rate(http_requests_total{job=\"markdown-backend\"}[1m]))",
                    "legendFormat": "req/sec"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "decimals": 2,
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "steps": [
                            {
                                "color": "green",
                                "value": 0
                            },
                            {
                                "color": "yellow",
                                "value": 10
                            },
                            {
                                "color": "red",
                                "value": 50
                            }
                        ]
                    }
                }
            }
        },
        {
            "id": 4,
            "title": "Memory Usage (MB)",
            "type": "stat",
            "gridPos": {
                "x": 12,
                "y": 0,
                "w": 4,
                "h": 4
            },
            "options": {
                "colorMode": "background",
                "graphMode": "area"
            },
            "targets": [
                {
                    "expr": "process_resident_memory_bytes{job=\"markdown-backend\"} / 1024 / 1024",
                    "legendFormat": "Memory MB"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "decimals": 1,
                    "unit": "MB",
                    "thresholds": {
                        "steps": [
                            {
                                "color": "green",
                                "value": 0
                            },
                            {
                                "color": "yellow",
                                "value": 200
                            },
                            {
                                "color": "red",
                                "value": 400
                            }
                        ]
                    }
                }
            }
        },
        {
            "id": 5,
            "title": "Active Connections",
            "type": "stat",
            "gridPos": {
                "x": 16,
                "y": 0,
                "w": 4,
                "h": 4
            },
            "options": {
                "colorMode": "background",
                "graphMode": "none"
            },
            "targets": [
                {
                    "expr": "http_active_connections{job=\"markdown-backend\"}",
                    "legendFormat": "Active"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "steps": [
                            {
                                "color": "green",
                                "value": 0
                            },
                            {
                                "color": "yellow",
                                "value": 50
                            },
                            {
                                "color": "red",
                                "value": 100
                            }
                        ]
                    }
                }
            }
        },
        {
            "id": 6,
            "title": "HTTP Request Rate Over Time",
            "type": "timeseries",
            "gridPos": {
                "x": 0,
                "y": 4,
                "w": 12,
                "h": 8
            },
            "options": {
                "tooltip": {
                    "mode": "multi"
                }
            },
            "targets": [
                {
                    "expr": "sum by(method, route) (rate(http_requests_total{job=\"markdown-backend\"}[1m]))",
                    "legendFormat": "{{method}} {{route}}"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps",
                    "custom": {
                        "lineWidth": 2,
                        "fillOpacity": 10
                    }
                }
            }
        },
        {
            "id": 7,
            "title": "Response Time (p50, p95, p99)",
            "type": "timeseries",
            "gridPos": {
                "x": 12,
                "y": 4,
                "w": 12,
                "h": 8
            },
            "options": {
                "tooltip": {
                    "mode": "multi"
                }
            },
            "targets": [
                {
                    "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"markdown-backend\"}[5m])) by (le))",
                    "legendFormat": "p50 (median)"
                },
                {
                    "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"markdown-backend\"}[5m])) by (le))",
                    "legendFormat": "p95"
                },
                {
                    "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"markdown-backend\"}[5m])) by (le))",
                    "legendFormat": "p99"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "s",
                    "custom": {
                        "lineWidth": 2,
                        "fillOpacity": 5
                    }
                }
            }
        },
        {
            "id": 8,
            "title": "CPU Usage Over Time",
            "type": "timeseries",
            "gridPos": {
                "x": 0,
                "y": 12,
                "w": 12,
                "h": 8
            },
            "targets": [
                {
                    "expr": "rate(process_cpu_seconds_total{job=\"markdown-backend\"}[1m]) * 100",
                    "legendFormat": "CPU %"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "percent",
                    "custom": {
                        "lineWidth": 2,
                        "fillOpacity": 15
                    },
                    "color": {
                        "fixedColor": "orange",
                        "mode": "fixed"
                    }
                }
            }
        },
        {
            "id": 9,
            "title": "Memory Usage Over Time",
            "type": "timeseries",
            "gridPos": {
                "x": 12,
                "y": 12,
                "w": 12,
                "h": 8
            },
            "targets": [
                {
                    "expr": "process_resident_memory_bytes{job=\"markdown-backend\"} / 1024 / 1024",
                    "legendFormat": "Memory (MB)"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "MB",
                    "custom": {
                        "lineWidth": 2,
                        "fillOpacity": 15
                    },
                    "color": {
                        "fixedColor": "purple",
                        "mode": "fixed"
                    }
                }
            }
        },
        {
            "id": 10,
            "title": "HTTP Status Codes Breakdown",
            "type": "piechart",
            "gridPos": {
                "x": 0,
                "y": 20,
                "w": 8,
                "h": 8
            },
            "options": {
                "pieType": "donut",
                "tooltip": {
                    "mode": "multi"
                }
            },
            "targets": [
                {
                    "expr": "sum by(status_code) (http_requests_total{job=\"markdown-backend\"})",
                    "legendFormat": "{{status_code}}"
                }
            ]
        },
        {
            "id": 11,
            "title": "Top Routes by Request Count",
            "type": "bargauge",
            "gridPos": {
                "x": 8,
                "y": 20,
                "w": 8,
                "h": 8
            },
            "options": {
                "orientation": "horizontal",
                "displayMode": "gradient"
            },
            "targets": [
                {
                    "expr": "topk(10, sum by(route) (http_requests_total{job=\"markdown-backend\"}))",
                    "legendFormat": "{{route}}"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "thresholds": {
                        "steps": [
                            {
                                "color": "blue",
                                "value": 0
                            }
                        ]
                    }
                }
            }
        },
        {
            "id": 12,
            "title": "Error Rate (5xx)",
            "type": "timeseries",
            "gridPos": {
                "x": 16,
                "y": 20,
                "w": 8,
                "h": 8
            },
            "targets": [
                {
                    "expr": "sum(rate(http_requests_total{job=\"markdown-backend\", status_code=~\"5..\"}[5m]))",
                    "legendFormat": "5xx errors/sec"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps",
                    "custom": {
                        "lineWidth": 2,
                        "fillOpacity": 20
                    },
                    "color": {
                        "fixedColor": "red",
                        "mode": "fixed"
                    }
                }
            }
        }
    ],
    "time": {
        "from": "now-1h",
        "to": "now"
    },
    "timepicker": {}
}